    "pg": "^8"
  },
  "devDependencies": {
    "typescript": "^5",
    "@types/bun": "latest",
    "@types/node": "^22",
    "@types/pg": "^8",
    "eslint": "^9",
    "prettier": "^3",
    "prisma": "^6",
    "tsx": "^4"
  },
  "prisma": {
    "seed": "bunx tsx prisma/seed.ts"
  }
}
